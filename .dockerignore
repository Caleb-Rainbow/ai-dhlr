# Git
.git
.gitignore

# Python
__pycache__
*.py[cod]
*$py.class
*.so
.Python
*.egg-info
.eggs
*.egg
.pytest_cache
.coverage
htmlcov
.tox
.nox

# 虚拟环境
venv
.venv
env
.env
ENV

# IDE
.idea
.vscode
*.swp
*.swo
*.sublime-project
*.sublime-workspace

# Node.js (前端依赖在容器内重新安装)
web/fire-monitor-ui/node_modules
web/fire-monitor-ui/dist
web/fire-monitor-ui/.vite

# 日志和快照
logs
snapshots
*.log

# 临时文件
*.tmp
*.temp
.tmp
.temp

# 测试
tests
pytest.ini

# 文档
docs
*.md
!README.md

# 模型文件 (太大，建议单独管理)
*.pt
*.onnx
*.rknn
*.whl
*.zip

# 本地配置 (生产环境使用环境变量或挂载)
# config/config.yaml

